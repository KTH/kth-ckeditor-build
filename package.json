{
  "name": "@kth/kth-ckeditor-build",
  "version": "4.0.0",
  "description": "Custom build of the CKEditor for use in KTH websites.",
  "keywords": [
    "kth",
    "ckeditor",
    "node"
  ],
  "main": "ckeditor/ckeditor.js",
  "files": [
    "ckeditor",
    "cssOverrides",
    "scripts",
    "customConfig",
    "plugins"
  ],
  "scripts": {
    "lint": "eslint --quiet",
    "lint-v": "eslint",
    "test": "echo \"ok\"",
    "test:watch": "echo \"ok\"",
    "build": "node scripts/build.js",
    "prepare": "bash -c 'if [ -f ./node_modules/.bin/husky ]; then husky install; fi'",
    "start": "nodemon --watch server --watch ckeditor --watch plugins --watch customConfig --watch cssOverrides --ext js,css,html --exec \"node server/app.js\"",
    "watch": "nodemon --watch ckeditor --watch plugins --watch customConfig --watch cssOverrides --ext js,css --exec \"node scripts/build.js\""
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:KTH/kth-ckeditor-build.git"
  },
  "bugs": {
    "url": "https://github.com/KTH/kth-ckeditor-build/issues"
  },
  "homepage": "https://github.com/KTH/kth-ckeditor-build#readme",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "author": {
    "name": "KTH",
    "email": "infosys@kth.se",
    "url": "https://github.com/KTH"
  },
  "devDependencies": {
    "@kth/eslint-config-kth": "^4.1.0",
    "babel-eslint": "^10.1.0",
    "bootstrap": "^5.3.8",
    "eslint": "^9.39.4",
    "express": "^4.22.2",
    "husky": "^7.0.4",
    "kth-style": "^7.0.29",
    "nodemon": "^3.1.14",
    "prettier": "^2.8.8",
    "pretty-quick": "3.3.1"
  },
  "husky": {
    "hooks": {
      "pre-push": "npm run test",
      "pre-commit": "pretty-quick --staged"
    }
  },
  "prettier": {
    "arrowParens": "avoid",
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5"
  }
}
