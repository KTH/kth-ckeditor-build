{
  "name": "@kth/kth-ckeditor-build",
  "version": "4.0.0",
  "description": "Custom build of the CKEditor for use in KTH websites.",
  "automaticPublish": "true",
  "main": "ckeditor/ckeditor.js",
  "scripts": {
    "build": "node scripts/build.js",
    "watch": "nodemon --watch ckeditor --watch plugins --watch customConfig --watch cssOverrides --ext js,css --exec \"node scripts/build.js\"",
    "prestart": "npm run build",
    "server": "nodemon server/app.js",
    "start": "npm-run-all --parallel watch server",
    "postversion": "git push && git push --tags",
    "test": "echo \"ok\"",
    "prepare": "bash -c 'if [ -f ./node_modules/.bin/husky ]; then husky install; fi'"
  },
  "keywords": [
    "kth",
    "ckeditor",
    "node"
  ],
  "author": {
    "name": "KTH",
    "email": "infosys@kth.se",
    "url": "https://github.com/KTH"
  },
  "license": "MIT",
  "files": [
    "ckeditor",
    "cssOverrides",
    "scripts",
    "customConfig",
    "plugins"
  ],
  "devDependencies": {
    "@kth/eslint-config-kth": "^2.0.2",
    "babel-eslint": "^10.1.0",
    "bootstrap": "^5.3.8",
    "eslint": "^7.32.0",
    "express": "^4.22.2",
    "hbs": "^4.2.1",
    "husky": "^7.0.4",
    "jquery": "^3.7.1",
    "kth-style": "^7.0.29",
    "limax": "^3.0.0",
    "morgan": "^1.11.0",
    "multer": "^1.4.4",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.8.8",
    "pretty-quick": "3.3.1"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:KTH/kth-ckeditor-build.git"
  },
  "engines": {
    "node": ">=16.6.2"
  },
  "husky": {
    "hooks": {
      "pre-push": "npm run test",
      "pre-commit": "pretty-quick --staged"
    }
  },
  "// (prettier)": "configuration version 2020-06-15 - might also reside in .prettierrc.json",
  "prettier": {
    "arrowParens": "avoid",
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5"
  }
}
